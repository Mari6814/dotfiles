[user]
	name = Marian Plivelic
	email = MarianPlivelic@gmail.com
[core]
	editor = vim
	excludesFile = ~/.gitignore
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[diff]
	tool = vimdiff
[alias]
    conflicts = diff --check
    l = log --oneline --decorate --graph
    la = log --oneline --decorate --graph --all
    s = status
    dt = difftool
    c = commit
    cm = commit -m
    cam = commit -am
    amend = commit --amend
    pick = cherry-pick
    a = add
    A = add -A
    cs = "!gh copilot suggest -t git"
    b = branch
    t = tag
    p = pull
    m = merge
    r = rebase
    wt = worktree
    wta = worktree add
    wtr = worktree remove
    wtl = worktree list
    bump = "!f_git_alias_bump() { \
      part=$1; \
      shift; \
      latest=$(git tag -l 'v[0-9]*' | sed 's/^v//' | sort -V | tail -n1); \
      [ -z \"$latest\" ] && latest=\"0.0.0\"; \
      major=$(echo $latest | cut -d. -f1); \
      minor=$(echo $latest | cut -d. -f2); \
      patch=$(echo $latest | cut -d. -f3); \
      case \"$part\" in \
        major) major=$((major+1)); minor=0; patch=0 ;; \
        minor) minor=$((minor+1)); patch=0 ;; \
        patch) patch=$((patch+1)) ;; \
        *) echo \"Usage: git bump [major|minor|patch] [-s]\"; exit 1 ;; \
      esac; \
      newtag=\"v${major}.${minor}.${patch}\"; \
      git tag \"$@\" $newtag && echo \"Created tag $newtag\"; \
    }; f_git_alias_bump"
    # Provides a preview of the remotes the push-mirrors command will push into
    show-mirrors = "!f_git_alias_show_mirrors() { \
        origin_url=$(git remote get-url origin); \
        if [ -z \"$origin_url\" ]; then \
            echo 'Error: origin remote has no URL!'; \
            return 1; \
        fi; \
        for remote in $(git remote); do \
            remote_url=$(git remote get-url $remote 2>/dev/null || echo ''); \
            if [ -n \"$remote_url\" ] && [ \"$remote_url\" != \"$origin_url\" ]; then \
                echo \"[dry-run] git push $remote --mirror\"; \
            fi; \
        done; \
    }; f_git_alias_show_mirrors"
    # pushes to all remotes that are not the current origin remote using --mirror flag
    push-mirrors = "!f_git_alias_push_mirrors() { \
        origin_url=$(git remote get-url origin); \
        if [ -z \"$origin_url\" ]; then \
            echo 'Error: origin remote has no URL!'; \
            return 1; \
        fi; \
        for remote in $(git remote); do \
            remote_url=$(git remote get-url $remote 2>/dev/null || echo ''); \
            if [ -n \"$remote_url\" ] && [ \"$remote_url\" != \"$origin_url\" ]; then \
                echo \"Mirroring to '$remote'\"; \
                git push --mirror $remote; \
            fi; \
        done; \
    }; f_git_alias_push_mirrors"
    # Generates remotes for all my common code mirrors
    add-mirrors = "!f_git_alias_add_mirrors() { \
        base_url=$(git remote get-url origin); \
        repo_name=$(basename -s .git $base_url); \
        if ! git remote get-url github >/dev/null 2>&1; then \
            git remote add github git@github.com:Mari6814/$repo_name.git; \
            echo 'Added GitHub remote'; \
        else \
            echo 'GitHub remote already exists'; \
        fi; \
        if ! git remote get-url codeberg >/dev/null 2>&1; then \
            git remote add codeberg ssh://git@codeberg.org/marianplivelic/$repo_name.git; \
            echo 'Added Codeberg remote'; \
        else \
            echo 'Codeberg remote already exists'; \
        fi; \
    }; f_git_alias_add_mirrors"
[difftool]
	prompt = false
[init]
	defaultBranch = main
[push]
	default = current
[pull]
    default = current
    rebase = true
[rebase]
    autoStash = true
[rerere]
	enabled = true
[commit]
	gpgsign = true
[tag]
	gpgSign = true
[include]
    path = ~/.gitconfig.local
