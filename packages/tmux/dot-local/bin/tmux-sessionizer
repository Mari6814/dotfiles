#!/usr/bin/env bash
# Example tmux usage:
# ```
# bind C-s display-popup -E "tmux-sessionizer"
# ```
# Add the above line to your ~/.tmux.conf to open tmux-sessionizer in a popup

if [[ $# -eq 1 ]]; then
    selected=$1
else
    IFS=':' read -ra search_dirs <<< "${TMUX_SESSIONIZER_PATHS:-$HOME/projects}"
    existing_dirs=()
    for dir in "${search_dirs[@]}"; do
        [[ -d "$dir" ]] && existing_dirs+=("$dir")
    done
    if [[ ${#existing_dirs[@]} -gt 0 ]]; then
        # Build "label<TAB>path" entries. The label (and thus the session name)
        # is prefixed with the search-dir it lives under ("root/repo") so that
        # repos with the same basename under different search dirs don't collide.
        # A bare repo expands to the bare repo itself plus each of its worktrees,
        # labelled "root/repo#worktree".
        entries=()
        while IFS= read -r dir; do
            label="$(basename "$(dirname "$dir")")/$(basename "$dir")"
            # A bare repo keeps its git files (HEAD, objects, refs) at the top
            # level; a normal project keeps them under .git. This cheap test
            # avoids spawning git for every (mostly non-bare) directory.
            if [[ -f "$dir/HEAD" && -d "$dir/objects" && -d "$dir/refs" ]]; then
                entries+=("$label"$'\t'"$dir")
                while IFS= read -r worktree; do
                    [[ "$worktree" == "$dir" ]] && continue
                    entries+=("$label#$(basename "$worktree")"$'\t'"$worktree")
                done < <(git -C "$dir" worktree list --porcelain \
                    | awk '/^worktree /{print $2}')
            else
                entries+=("$label"$'\t'"$dir")
            fi
        done < <(find "${existing_dirs[@]}" -mindepth 1 -maxdepth 1 -type d)
        selection=$(printf '%s\n' "${entries[@]}" | fzf --delimiter='\t' --with-nth=1)
        if [[ -n $selection ]]; then
            selected=${selection#*$'\t'}
            session_name=$(printf '%s' "${selection%%$'\t'*}" | tr . _)
        fi
    fi
fi

if [[ -z $selected ]]; then
    exit 0
fi

session_name=${session_name:-$(basename "$selected" | tr . _)}

# Create the session if it doesn't exist
if ! tmux has-session -t "=$session_name" 2>/dev/null; then
    tmux new-session -ds "$session_name" -c "$selected"
fi

if [[ ! -z ${TMUX:-} ]]; then
    # If we are already in a tmux session, attach to the new session on window with id 0
    tmux switch-client -t "=$session_name"
else
    # If we are not in a tmux session, attach to the new session
    tmux attach-session -t "=$session_name"
fi
